# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Agent prompt files (generated per-session by launchers)
AGENTS.md

# Experimental code/artifacts
dev/

# Results file + run logs (agent writes these)
results.tsv
run.log

# Side-channel OOS audit log written by the harness (agent must NOT cat).
# `.old` variants are migration backups kept when the schema changes.
oos_results.tsv
oos_results.tsv.old*

# Per-commit null-test and sensitivity-sweep audits (written by
# null_test.py / sensitivity.py — belong outside git, same as results.tsv).
null_results_*.json
sensitivity_results_*.json

# Jupyter
.ipynb_checkpoints/

# Autoresearch worktrees (one per experiment branch; parallel-safe scratch)
worktrees/
